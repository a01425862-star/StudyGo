<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#0047CC">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="StudyGo">
<title>StudyGo</title>
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icons/icon-192.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
<script defer src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
<style>
/*══════════════════════════════════════════
  PALETTE: deep blue · baby blue · white · yellow · red
══════════════════════════════════════════*/
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  /* Brand palette */
  --deep:#0033AA;
  --blue:#0057FF;
  --baby:#6ABAFF;
  --sky:#C6E4FF;
  --white:#FFFFFF;
  --yellow:#FFD600;
  --red:#FF2D2D;
  --red-dark:#CC0000;

  /* Surfaces */
  --bg:#00061A;
  --bg2:#000D2E;
  --surface:#040F2E;
  --surface2:#081640;
  --border:rgba(106,186,255,0.12);
  --border2:rgba(106,186,255,0.22);
  --text:#E8F4FF;
  --muted:rgba(106,186,255,0.45);

  --safe-top:env(safe-area-inset-top,0px);
  --safe-bottom:env(safe-area-inset-bottom,0px);
}

html{height:100%}
body{
  min-height:100vh;
  background:var(--bg);
  background-image:
    radial-gradient(ellipse at 15% 20%, rgba(0,87,255,0.18) 0%, transparent 55%),
    radial-gradient(ellipse at 85% 80%, rgba(0,51,170,0.22) 0%, transparent 55%),
    radial-gradient(ellipse at 50% 50%, rgba(0,6,26,0) 0%, var(--bg) 100%);
  font-family:'Rajdhani',sans-serif;
  color:var(--text);
  -webkit-tap-highlight-color:transparent;
  overflow-x:hidden;
}

/* subtle grid overlay */
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:
    linear-gradient(rgba(106,186,255,0.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(106,186,255,0.03) 1px,transparent 1px);
  background-size:40px 40px;
}

/*══════════════════════════════════════════
  PAGES
══════════════════════════════════════════*/
.page{
  display:none;flex-direction:column;align-items:center;position:relative;z-index:1;
  padding:calc(28px + var(--safe-top)) 18px calc(80px + var(--safe-bottom));
  gap:22px;min-height:100vh;
}
.page.active{display:flex}

/*══════════════════════════════════════════
  TOPBAR
══════════════════════════════════════════*/
.topbar{
  width:100%;max-width:700px;
  display:flex;align-items:center;justify-content:space-between;flex-shrink:0;
}
.brand{
  font-family:'Orbitron',sans-serif;
  font-size:1.9rem;font-weight:900;letter-spacing:5px;
  background:linear-gradient(120deg,var(--white) 0%,var(--baby) 60%,var(--yellow) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  cursor:pointer;
  filter:drop-shadow(0 0 18px rgba(106,186,255,0.5));
  animation:brandPulse 4s ease-in-out infinite;
}
@keyframes brandPulse{
  0%,100%{filter:drop-shadow(0 0 18px rgba(106,186,255,0.5))}
  50%{filter:drop-shadow(0 0 30px rgba(106,186,255,0.85))}
}

/* counter pill */
.counter{
  background:rgba(0,87,255,0.12);
  border:1.5px solid var(--border2);
  border-radius:50px;padding:7px 16px;
  display:flex;align-items:center;gap:9px;backdrop-filter:blur(12px);
}
.counter svg{width:20px;height:20px;fill:none;stroke:var(--baby);stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.counter-text{font-family:'Orbitron',sans-serif;font-size:.9rem;font-weight:700;color:var(--white);letter-spacing:2px}
.counter-text span{color:var(--yellow)}

/* page badge top-right */
.page-badge{
  font-family:'Orbitron',sans-serif;font-size:.55rem;
  letter-spacing:2px;padding:5px 12px;border-radius:20px;font-weight:700;
}
.badge-yellow{background:rgba(255,214,0,0.12);border:1px solid rgba(255,214,0,0.3);color:var(--yellow)}
.badge-red{background:rgba(255,45,45,0.12);border:1px solid rgba(255,45,45,0.3);color:var(--red)}
.badge-baby{background:rgba(106,186,255,0.12);border:1px solid rgba(106,186,255,0.3);color:var(--baby)}

/*══════════════════════════════════════════
  BOTTOM NAV DOCK
══════════════════════════════════════════*/
.nav-dock{
  position:fixed;bottom:calc(14px + var(--safe-bottom));left:50%;transform:translateX(-50%);
  background:rgba(4,15,46,0.95);backdrop-filter:blur(20px);
  border:1.5px solid var(--border2);border-radius:22px;
  padding:10px 6px;display:flex;gap:2px;z-index:100;
  box-shadow:0 8px 40px rgba(0,0,0,0.6),0 0 0 1px rgba(106,186,255,0.05);
}
.nav-item{
  display:flex;flex-direction:column;align-items:center;gap:4px;
  padding:8px 16px;border-radius:16px;cursor:pointer;
  font-family:'Orbitron',sans-serif;font-size:.5rem;letter-spacing:1.5px;
  color:rgba(106,186,255,0.35);transition:all .25s;user-select:none;
}
.nav-item svg{width:20px;height:20px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;transition:all .25s}
.nav-item.active{background:rgba(0,87,255,0.2);color:var(--baby)}
.nav-item.active svg{stroke:var(--baby);filter:drop-shadow(0 0 6px rgba(106,186,255,0.7))}
.nav-item.active.ynav{background:rgba(255,214,0,0.12);color:var(--yellow)}
.nav-item.active.ynav svg{stroke:var(--yellow);filter:drop-shadow(0 0 6px rgba(255,214,0,0.6))}
.nav-item.active.rnav{background:rgba(255,45,45,0.1);color:var(--red)}
.nav-item.active.rnav svg{stroke:var(--red);filter:drop-shadow(0 0 6px rgba(255,45,45,0.5))}

/*══════════════════════════════════════════
  PAGE 1 — ATTENDANCE
══════════════════════════════════════════*/

/* HERO attendance card */
.attendance-card{
  width:100%;max-width:700px;min-height:280px;
  background:linear-gradient(145deg,#040F2E,#081640,#040F2E);
  border:2px solid rgba(0,87,255,0.5);border-radius:24px;
  box-shadow:0 0 60px rgba(0,87,255,0.2),inset 0 0 80px rgba(0,87,255,0.04);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:20px;padding:36px 24px;position:relative;overflow:hidden;cursor:pointer;
  transition:box-shadow .25s,border-color .25s;
}
/* diagonal stripe texture */
.attendance-card::after{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:repeating-linear-gradient(
    -55deg,
    transparent,transparent 14px,
    rgba(0,87,255,0.025) 14px,rgba(0,87,255,0.025) 15px
  );
}
.attendance-card.active,.attendance-card:hover{
  box-shadow:0 0 80px rgba(0,87,255,0.35),inset 0 0 60px rgba(0,87,255,0.07);
  border-color:var(--baby);
}

/* decorative top-right dot cluster */
.card-deco{
  position:absolute;top:16px;right:20px;
  display:flex;gap:5px;align-items:center;pointer-events:none;
}
.card-deco span{
  width:7px;height:7px;border-radius:50%;
  background:var(--blue);opacity:.35;
}
.card-deco span:nth-child(2){background:var(--baby);opacity:.5}
.card-deco span:nth-child(3){background:var(--yellow);opacity:.6}

.attendance-label{
  font-family:'Orbitron',sans-serif;font-size:2.2rem;font-weight:900;
  letter-spacing:7px;
  background:linear-gradient(135deg,var(--white),var(--baby));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 0 16px rgba(106,186,255,0.5));
  pointer-events:none;position:relative;z-index:1;
}
.hint-text{
  font-size:.75rem;letter-spacing:2px;color:var(--muted);font-weight:600;
  pointer-events:none;transition:opacity .2s;position:relative;z-index:1;
}
.attendance-card.active .hint-text{opacity:0;pointer-events:none}

.add-area{
  display:flex;gap:10px;width:100%;max-width:500px;position:relative;z-index:1;
  opacity:0;transform:translateY(8px);transition:opacity .25s,transform .25s;pointer-events:none;
}
.attendance-card.active .add-area{opacity:1;transform:translateY(0);pointer-events:all}
.add-area input{
  flex:1;background:rgba(0,0,0,.5);
  border:1.5px solid rgba(106,186,255,0.25);border-radius:12px;
  color:var(--sky);font-family:'Rajdhani',sans-serif;font-size:1rem;font-weight:600;
  padding:10px 16px;outline:none;letter-spacing:1px;transition:border-color .2s;-webkit-appearance:none;
}
.add-area input::placeholder{color:rgba(106,186,255,0.3)}
.add-area input:focus{border-color:var(--baby)}
.add-area button{
  background:linear-gradient(135deg,var(--blue),var(--deep));
  border:none;border-radius:12px;
  color:var(--white);font-family:'Orbitron',sans-serif;font-size:.7rem;font-weight:700;
  letter-spacing:2px;padding:10px 20px;cursor:pointer;transition:all .2s;touch-action:manipulation;
  box-shadow:0 0 20px rgba(0,87,255,0.4);
}
.add-area button:hover{background:linear-gradient(135deg,var(--baby),var(--blue));box-shadow:0 0 30px rgba(106,186,255,0.5)}
.add-area button:active{transform:scale(.96)}

.attendance-list{
  width:100%;max-width:500px;display:flex;flex-direction:column;gap:8px;
  max-height:220px;overflow-y:auto;padding:0 4px;position:relative;z-index:1;
}
.attendance-list::-webkit-scrollbar{width:3px}
.attendance-list::-webkit-scrollbar-thumb{background:rgba(106,186,255,0.25);border-radius:4px}

.student-entry{
  display:flex;align-items:center;gap:14px;
  background:rgba(0,87,255,0.08);border:1px solid rgba(106,186,255,0.15);
  border-radius:10px;padding:9px 14px;animation:slideIn .3s ease both;
}
@keyframes slideIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.student-num{font-family:'Orbitron',sans-serif;font-size:.65rem;color:var(--baby);min-width:26px;font-weight:700}
.student-name{flex:1;font-size:1rem;font-weight:600;color:var(--sky);letter-spacing:.5px}
.student-check{color:var(--yellow);font-size:1rem}

/* FACE ID card — full width, bold */
.faceid-hero{
  width:100%;max-width:700px;
  background:linear-gradient(135deg,#000D2E 0%,#001570 50%,#000D2E 100%);
  border:2px solid var(--blue);border-radius:24px;
  padding:40px 32px;
  display:flex;flex-direction:column;align-items:center;gap:14px;
  cursor:pointer;position:relative;overflow:hidden;
  transition:all .25s;
  box-shadow:0 0 50px rgba(0,87,255,0.25),inset 0 0 60px rgba(0,87,255,0.06);
}
.faceid-hero::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 50% 0%,rgba(106,186,255,0.12),transparent 70%);
  pointer-events:none;
}
/* animated ring */
.faceid-hero::after{
  content:'';position:absolute;
  width:200px;height:200px;border-radius:50%;
  border:1px solid rgba(106,186,255,0.08);
  top:50%;left:50%;transform:translate(-50%,-50%);
  animation:ringPulse 3s ease-in-out infinite;pointer-events:none;
}
@keyframes ringPulse{
  0%,100%{width:180px;height:180px;opacity:.5}
  50%{width:240px;height:240px;opacity:.15}
}
.faceid-hero:hover{
  box-shadow:0 0 80px rgba(0,87,255,0.45),inset 0 0 60px rgba(106,186,255,0.1);
  border-color:var(--baby);transform:translateY(-3px);
}
.faceid-hero:active{transform:scale(.98)}

.faceid-icon-wrap{
  position:relative;z-index:1;
  width:80px;height:80px;border-radius:50%;
  background:rgba(0,87,255,0.15);border:2px solid rgba(106,186,255,0.3);
  display:flex;align-items:center;justify-content:center;font-size:2.4rem;
  box-shadow:0 0 30px rgba(0,87,255,0.3);
}
.faceid-label{
  font-family:'Orbitron',sans-serif;font-size:1.6rem;font-weight:900;
  letter-spacing:6px;color:var(--white);
  text-shadow:0 0 20px rgba(106,186,255,0.6);
  position:relative;z-index:1;
}
.faceid-sub{
  font-family:'Orbitron',sans-serif;font-size:.65rem;
  letter-spacing:3px;color:var(--baby);opacity:.6;
  position:relative;z-index:1;
}
/* scan bar animation on hero */
.faceid-scanbar{
  position:absolute;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent 0%,var(--baby) 40%,var(--white) 50%,var(--baby) 60%,transparent 100%);
  animation:heroScan 3s linear infinite;opacity:.5;
}
@keyframes heroScan{0%{top:-4px;opacity:0}10%{opacity:.6}90%{opacity:.6}100%{top:100%;opacity:0}}

/*══════════════════════════════════════════
  PAGE 2 — SCHOOL ADMIN
══════════════════════════════════════════*/
.page-header{width:100%;max-width:700px;display:flex;flex-direction:column;gap:4px}
.page-title{font-family:'Orbitron',sans-serif;font-size:1.3rem;font-weight:900;letter-spacing:4px}
.page-subtitle{font-size:.8rem;letter-spacing:1.5px;color:var(--muted);font-weight:600}

.search-bar{width:100%;max-width:700px;display:flex;gap:10px}
.search-bar input{
  flex:1;background:rgba(0,87,255,0.06);
  border:1.5px solid var(--border);border-radius:14px;
  color:var(--text);font-family:'Rajdhani',sans-serif;font-size:1rem;font-weight:600;
  padding:11px 18px;outline:none;letter-spacing:.5px;transition:border-color .2s;
}
.search-bar input::placeholder{color:rgba(106,186,255,0.25)}
.search-bar input:focus{border-color:var(--border2)}

.btn-add-student{
  background:linear-gradient(135deg,rgba(255,214,0,0.15),rgba(255,214,0,0.05));
  border:1.5px solid rgba(255,214,0,0.4);border-radius:14px;
  color:var(--yellow);font-family:'Orbitron',sans-serif;
  font-size:.6rem;font-weight:700;letter-spacing:2px;
  padding:11px 16px;cursor:pointer;transition:all .2s;white-space:nowrap;
}
.btn-add-student:hover{background:var(--yellow);color:#1a1000;box-shadow:0 0 20px rgba(255,214,0,0.3)}

.students-grid{
  width:100%;max-width:700px;
  display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:14px;
}
.student-card{
  background:var(--surface);border:1.5px solid var(--border);border-radius:18px;
  padding:20px 14px;display:flex;flex-direction:column;align-items:center;gap:10px;
  cursor:pointer;transition:all .2s;position:relative;overflow:hidden;
}
.student-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--blue),var(--baby),var(--yellow));
  opacity:0;transition:opacity .2s;
}
.student-card:hover{border-color:var(--border2);transform:translateY(-3px);box-shadow:0 8px 28px rgba(0,0,0,.4)}
.student-card:hover::before{opacity:1}
.student-avatar{
  width:68px;height:68px;border-radius:50%;
  background:linear-gradient(135deg,var(--surface2),var(--bg2));
  border:2px solid rgba(0,87,255,0.25);overflow:hidden;
  display:flex;align-items:center;justify-content:center;
  font-size:1.7rem;position:relative;
}
.student-avatar img{width:100%;height:100%;object-fit:cover}
.avatar-badge{
  position:absolute;bottom:0;right:0;
  width:18px;height:18px;border-radius:50%;border:2px solid var(--surface);
  display:flex;align-items:center;justify-content:center;font-size:.5rem;font-weight:700;
}
.avatar-badge.has-descriptor{background:var(--blue);color:#fff}
.avatar-badge.no-descriptor{background:#1a2040;color:#445}
.sc-name{font-family:'Orbitron',sans-serif;font-size:.75rem;font-weight:700;letter-spacing:1px;text-align:center;color:var(--sky)}
.sc-id{font-size:.72rem;color:var(--muted);letter-spacing:.5px}
.sc-attendance{
  font-size:.68rem;letter-spacing:1px;font-weight:700;
  background:rgba(0,87,255,0.1);border:1px solid rgba(0,87,255,0.2);
  border-radius:20px;padding:3px 10px;color:var(--baby);
}
.empty-state{
  width:100%;max-width:700px;
  display:flex;flex-direction:column;align-items:center;gap:14px;
  padding:60px 20px;color:#1a2a50;
}
.empty-state svg{width:56px;height:56px;fill:none;stroke:#1a2a50;stroke-width:1.5}
.empty-state p{font-family:'Orbitron',sans-serif;font-size:.7rem;letter-spacing:2px}

/*══════════════════════════════════════════
  MODALS (shared base)
══════════════════════════════════════════*/
.modal-overlay{
  position:fixed;inset:0;background:rgba(0,3,18,.9);backdrop-filter:blur(12px);
  display:flex;align-items:center;justify-content:center;
  z-index:200;opacity:0;pointer-events:none;transition:opacity .25s;padding:16px;
}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{
  background:var(--surface);border-radius:24px;
  padding:28px 24px;display:flex;flex-direction:column;align-items:center;gap:18px;
  max-width:500px;width:100%;max-height:92vh;overflow-y:auto;
  transform:scale(.91) translateY(10px);transition:transform .28s ease;
  border:1.5px solid var(--border2);
  box-shadow:0 24px 80px rgba(0,0,0,.7),0 0 0 1px rgba(106,186,255,0.06);
}
.modal-overlay.open .modal{transform:scale(1) translateY(0)}

/* student detail */
.detail-modal{border-color:rgba(0,87,255,0.35)}
.detail-avatar{
  width:96px;height:96px;border-radius:50%;
  background:linear-gradient(135deg,var(--surface2),var(--bg2));
  border:2px solid rgba(0,87,255,0.35);overflow:hidden;
  display:flex;align-items:center;justify-content:center;font-size:2.6rem;
  position:relative;cursor:pointer;transition:border-color .2s;
}
.detail-avatar:hover{border-color:var(--baby)}
.detail-avatar img{width:100%;height:100%;object-fit:cover}
.detail-avatar .upload-hint{
  position:absolute;inset:0;background:rgba(0,0,0,.65);
  display:flex;align-items:center;justify-content:center;
  opacity:0;transition:opacity .2s;border-radius:50%;
  font-size:.55rem;font-family:'Orbitron',sans-serif;letter-spacing:1px;color:#fff;text-align:center;padding:8px;
}
.detail-avatar:hover .upload-hint{opacity:1}
.detail-name{font-family:'Orbitron',sans-serif;font-size:1.1rem;font-weight:900;letter-spacing:3px;color:var(--white)}
.detail-meta{display:flex;gap:8px;flex-wrap:wrap;justify-content:center}
.meta-tag{font-size:.65rem;letter-spacing:1.5px;font-weight:700;border-radius:20px;padding:4px 12px}
.meta-blue{background:rgba(0,87,255,0.15);border:1px solid rgba(0,87,255,0.3);color:var(--baby)}
.meta-yellow{background:rgba(255,214,0,0.1);border:1px solid rgba(255,214,0,0.25);color:var(--yellow)}
.meta-white{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.14);color:#aac}
.meta-red{background:rgba(255,45,45,0.1);border:1px solid rgba(255,45,45,0.22);color:var(--red)}

.descriptor-section{
  width:100%;background:rgba(0,0,0,.25);border:1.5px solid var(--border);
  border-radius:14px;padding:16px;
}
.desc-title{font-family:'Orbitron',sans-serif;font-size:.6rem;letter-spacing:2px;color:var(--muted);margin-bottom:10px}
.descriptor-status{display:flex;align-items:center;gap:10px;font-size:.85rem;font-weight:600;letter-spacing:.5px;color:var(--sky)}
.desc-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.desc-dot.ok{background:var(--baby);box-shadow:0 0 8px var(--baby)}
.desc-dot.none{background:#1a2a50}
.desc-actions{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap}

.btn-sm{
  border:none;border-radius:9px;
  font-family:'Orbitron',sans-serif;font-size:.58rem;font-weight:700;letter-spacing:1.5px;
  padding:8px 14px;cursor:pointer;transition:all .2s;touch-action:manipulation;
}
.btn-generate{background:linear-gradient(135deg,var(--blue),var(--deep));color:#fff;box-shadow:0 0 16px rgba(0,87,255,0.3)}
.btn-generate:hover{background:linear-gradient(135deg,var(--baby),var(--blue));box-shadow:0 0 24px rgba(106,186,255,0.4)}
.btn-generate:disabled{opacity:.4;cursor:default}
.btn-outline{background:transparent;border:1.5px solid rgba(106,186,255,0.15);color:var(--muted)}
.btn-outline:hover{border-color:var(--baby);color:var(--baby)}
.btn-danger{background:rgba(255,45,45,0.1);border:1.5px solid rgba(255,45,45,0.2);color:var(--red)}
.btn-danger:hover{background:rgba(255,45,45,0.2);box-shadow:0 0 12px rgba(255,45,45,0.2)}
.btn-yellow{background:linear-gradient(135deg,rgba(255,214,0,.2),rgba(255,214,0,.08));border:1.5px solid rgba(255,214,0,.35);color:var(--yellow)}
.btn-yellow:hover{background:var(--yellow);color:#1a1000}

.att-log{width:100%;display:flex;flex-direction:column;gap:6px;max-height:150px;overflow-y:auto}
.att-log::-webkit-scrollbar{width:3px}
.att-log::-webkit-scrollbar-thumb{background:rgba(106,186,255,0.15);border-radius:3px}
.att-row{
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(0,87,255,0.05);border-radius:8px;padding:7px 12px;font-size:.8rem;
}
.att-date{color:var(--muted);font-size:.72rem;letter-spacing:.5px}
.att-present{color:var(--baby);font-weight:700;font-size:.72rem;letter-spacing:1px}
.att-absent{color:var(--red);font-weight:700;font-size:.72rem;letter-spacing:1px}

.modal-form{width:100%;display:flex;flex-direction:column;gap:12px}
.form-field{display:flex;flex-direction:column;gap:5px}
.form-label{font-family:'Orbitron',sans-serif;font-size:.58rem;letter-spacing:2px;color:var(--muted)}
.form-input{
  background:rgba(0,87,255,0.06);border:1.5px solid var(--border);
  border-radius:11px;color:var(--text);font-family:'Rajdhani',sans-serif;
  font-size:1rem;font-weight:600;padding:10px 14px;outline:none;transition:border-color .2s;-webkit-appearance:none;
}
.form-input:focus{border-color:var(--baby)}
.form-input::placeholder{color:rgba(106,186,255,0.2)}

.modal-title{font-family:'Orbitron',sans-serif;font-size:1rem;font-weight:900;letter-spacing:3px;text-align:center;color:var(--white)}
.modal-btns{display:flex;gap:10px;width:100%}
.btn-primary{
  flex:1;border:none;border-radius:11px;
  background:linear-gradient(135deg,var(--blue),var(--deep));color:#fff;
  font-family:'Orbitron',sans-serif;font-size:.65rem;font-weight:700;letter-spacing:2px;
  padding:12px;cursor:pointer;transition:all .2s;
  box-shadow:0 0 20px rgba(0,87,255,0.3);
}
.btn-primary:hover{background:linear-gradient(135deg,var(--baby),var(--blue));box-shadow:0 0 30px rgba(106,186,255,0.4)}
.btn-close-modal{
  flex:1;border-radius:11px;background:transparent;
  border:1.5px solid rgba(106,186,255,0.12);color:rgba(106,186,255,0.4);
  font-family:'Orbitron',sans-serif;font-size:.65rem;font-weight:700;
  letter-spacing:2px;padding:12px;cursor:pointer;transition:all .2s;
}
.btn-close-modal:hover{border-color:var(--baby);color:var(--baby)}
.divider{width:100%;height:1px;background:var(--border)}

/*══════════════════════════════════════════
  CAMERA MODAL
══════════════════════════════════════════*/
.cam-modal{border-color:rgba(0,87,255,0.4)}
.cam-modal .modal-title{color:var(--baby);text-shadow:0 0 12px rgba(106,186,255,0.5)}
.camera-wrap{
  width:100%;aspect-ratio:4/3;background:#000;
  border-radius:16px;overflow:hidden;position:relative;
  display:flex;align-items:center;justify-content:center;
  border:1.5px solid rgba(0,87,255,0.2);
}
.camera-wrap video{width:100%;height:100%;object-fit:cover;display:none;transform:scaleX(-1)}
.camera-wrap video.live{display:block}
.cam-placeholder{display:flex;flex-direction:column;align-items:center;gap:12px;color:#1a2a50;font-family:'Orbitron',sans-serif;font-size:.65rem;letter-spacing:2px}
.cam-placeholder svg{width:60px;height:60px;fill:none;stroke:#1a2a50;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.scan-line{
  position:absolute;left:0;right:0;height:2px;display:none;
  background:linear-gradient(90deg,transparent,var(--baby),var(--white),var(--baby),transparent);
  animation:scanMove 2.2s linear infinite;
}
.scan-line.active{display:block}
@keyframes scanMove{0%{top:0;opacity:0}5%{opacity:1}95%{opacity:1}100%{top:100%;opacity:0}}
.corners{position:absolute;inset:14px;pointer-events:none}
.corner{position:absolute;width:22px;height:22px;border-style:solid;border-color:var(--baby);display:none}
.corner.on{display:block}
.corner.tl{top:0;left:0;border-width:2px 0 0 2px}
.corner.tr{top:0;right:0;border-width:2px 2px 0 0}
.corner.bl{bottom:0;left:0;border-width:0 0 2px 2px}
.corner.br{bottom:0;right:0;border-width:0 2px 2px 0}
.modal-status{font-size:.75rem;letter-spacing:2px;font-weight:600;min-height:1.1em;text-align:center;color:rgba(106,186,255,.5)}
.processing-overlay{
  position:absolute;inset:0;background:rgba(0,0,0,.75);
  display:none;align-items:center;justify-content:center;
  flex-direction:column;gap:12px;border-radius:16px;
}
.processing-overlay.show{display:flex}
.proc-text{font-family:'Orbitron',sans-serif;font-size:.6rem;letter-spacing:2px;color:var(--baby)}

/*══════════════════════════════════════════
  PAGE 3 — STUDENT PROFILE
══════════════════════════════════════════*/
.student-picker-grid{
  width:100%;max-width:700px;
  display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;
}
.picker-card{
  background:var(--surface);border:1.5px solid var(--border);border-radius:18px;
  padding:20px 12px;display:flex;flex-direction:column;align-items:center;gap:10px;
  cursor:pointer;transition:all .22s;position:relative;overflow:hidden;
}
.picker-card::after{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 50% 0%,rgba(0,87,255,0.08),transparent 70%);
  opacity:0;transition:opacity .2s;
}
.picker-card:hover{border-color:var(--baby);transform:translateY(-3px);box-shadow:0 8px 28px rgba(0,87,255,0.2)}
.picker-card:hover::after{opacity:1}
.picker-card:active{transform:scale(.96)}
.picker-avatar{
  width:60px;height:60px;border-radius:50%;
  background:linear-gradient(135deg,var(--surface2),var(--bg2));
  border:2px solid rgba(0,87,255,0.2);overflow:hidden;
  display:flex;align-items:center;justify-content:center;font-size:1.5rem;
}
.picker-avatar img{width:100%;height:100%;object-fit:cover}
.picker-name{
  font-family:'Orbitron',sans-serif;font-size:.65rem;font-weight:700;
  letter-spacing:.5px;text-align:center;color:var(--sky);line-height:1.3;
}
.picker-class{font-size:.65rem;color:var(--muted);letter-spacing:.5px}

/* profile hero */
.profile-hero{
  width:100%;max-width:700px;
  background:linear-gradient(145deg,#040F2E,#060f2a,#040F2E);
  border:2px solid rgba(0,87,255,0.3);border-radius:24px;
  padding:28px 20px;display:flex;flex-direction:column;align-items:center;gap:14px;
  position:relative;overflow:hidden;
}
.profile-hero::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 50% -10%,rgba(0,87,255,0.18),transparent 60%);
  pointer-events:none;
}
/* red accent bar on top */
.profile-hero::after{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--blue),var(--baby),var(--yellow),var(--red));
  border-radius:24px 24px 0 0;
}
.profile-big-avatar{
  width:96px;height:96px;border-radius:50%;
  background:linear-gradient(135deg,var(--surface2),var(--bg2));
  border:3px solid rgba(0,87,255,0.4);overflow:hidden;
  display:flex;align-items:center;justify-content:center;font-size:2.8rem;
  box-shadow:0 0 30px rgba(0,87,255,0.25);position:relative;z-index:1;
}
.profile-big-avatar img{width:100%;height:100%;object-fit:cover}
.profile-name{font-family:'Orbitron',sans-serif;font-size:1.25rem;font-weight:900;letter-spacing:3px;text-align:center;color:var(--white);position:relative;z-index:1}
.profile-id{font-size:.75rem;letter-spacing:2px;color:var(--muted);font-weight:600;position:relative;z-index:1}
.profile-stats{
  display:grid;grid-template-columns:repeat(3,1fr);gap:10px;width:100%;max-width:380px;position:relative;z-index:1;
}
.stat-box{
  background:rgba(0,87,255,0.08);border:1px solid rgba(0,87,255,0.15);
  border-radius:12px;padding:12px;text-align:center;
}
.stat-val{font-family:'Orbitron',sans-serif;font-size:1.4rem;font-weight:900}
.stat-val.present-val{color:var(--baby)}
.stat-val.absent-val{color:var(--red)}
.stat-val.rate-val{color:var(--yellow)}
.stat-label{font-size:.58rem;letter-spacing:1.5px;color:var(--muted);margin-top:2px}

/* calendar */
.calendar-wrap{
  width:100%;max-width:700px;
  background:var(--surface);border:1.5px solid var(--border);border-radius:18px;padding:18px;
}
.cal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.cal-title{font-family:'Orbitron',sans-serif;font-size:.75rem;letter-spacing:2px;color:var(--baby)}
.cal-nav{display:flex;gap:6px}
.cal-nav button{
  background:rgba(0,87,255,0.08);border:1px solid var(--border);
  border-radius:8px;padding:5px 10px;cursor:pointer;color:var(--muted);
  font-size:.85rem;transition:all .2s;
}
.cal-nav button:hover{border-color:var(--baby);color:var(--baby)}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px}
.cal-day-name{font-family:'Orbitron',sans-serif;font-size:.5rem;letter-spacing:1px;color:rgba(106,186,255,0.3);text-align:center;padding:3px 0}
.cal-day{aspect-ratio:1;display:flex;align-items:center;justify-content:center;border-radius:7px;font-size:.78rem;font-weight:600;transition:all .15s}
.cal-day.empty{opacity:0}
.cal-day.today{border:1.5px solid rgba(106,186,255,0.4);color:var(--white);font-weight:700}
.cal-day.present{background:rgba(0,87,255,0.2);color:var(--baby);font-weight:700}
.cal-day.absent{background:rgba(255,45,45,0.1);color:rgba(255,45,45,0.55)}
.cal-day.future{color:#1a2a50}

/* att summary */
.att-summary{
  width:100%;max-width:700px;
  background:var(--surface);border:1.5px solid var(--border);border-radius:18px;overflow:hidden;
}
.att-summary-header{
  padding:14px 18px;border-bottom:1px solid var(--border);
  font-family:'Orbitron',sans-serif;font-size:.65rem;letter-spacing:2px;color:var(--muted);
}
.att-item{
  display:flex;align-items:center;gap:12px;padding:12px 18px;
  border-bottom:1px solid rgba(0,87,255,0.05);transition:background .15s;
}
.att-item:last-child{border-bottom:none}
.att-item:hover{background:rgba(0,87,255,0.04)}
.att-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.att-dot.p{background:var(--baby);box-shadow:0 0 6px rgba(106,186,255,0.5)}
.att-dot.a{background:var(--red)}
.att-item-date{flex:1;font-size:.85rem;font-weight:600;color:#8aa}
.att-item-class{font-size:.72rem;color:var(--muted);letter-spacing:.3px}
.att-item-status{font-family:'Orbitron',sans-serif;font-size:.58rem;letter-spacing:1.5px;font-weight:700}
.att-item-status.p{color:var(--baby)}
.att-item-status.a{color:var(--red)}

/* back / sign-out */
.sign-out-btn{
  background:rgba(255,45,45,0.08);border:1.5px solid rgba(255,45,45,0.2);
  border-radius:10px;padding:7px 16px;
  font-family:'Orbitron',sans-serif;font-size:.58rem;letter-spacing:2px;
  color:var(--red);cursor:pointer;transition:all .2s;
}
.sign-out-btn:hover{background:rgba(255,45,45,0.18)}

/*══════════════════════════════════════════
  SPINNER / TOAST / OFFLINE
══════════════════════════════════════════*/
.spinner{
  width:20px;height:20px;border:2px solid rgba(106,186,255,.1);
  border-top-color:var(--baby);border-radius:50%;
  animation:spin .7s linear infinite;display:inline-block;
}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.fade-up{animation:fadeUp .5s ease both}

#toast{
  position:fixed;bottom:calc(88px + var(--safe-bottom));left:50%;transform:translateX(-50%) translateY(16px);
  background:var(--surface2);border:1.5px solid var(--border2);border-radius:14px;
  padding:9px 20px;font-family:'Orbitron',sans-serif;font-size:.6rem;letter-spacing:2px;
  white-space:nowrap;opacity:0;transition:all .3s;z-index:500;pointer-events:none;color:var(--baby);
}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
#toast.yellow{border-color:rgba(255,214,0,.4);color:var(--yellow)}
#toast.red{border-color:rgba(255,45,45,.4);color:var(--red)}
#toast.green{border-color:rgba(106,186,255,.4);color:var(--baby)}

#offlineBadge{
  display:none;position:fixed;bottom:calc(14px + var(--safe-bottom));right:14px;
  background:#100010;border:1.5px solid var(--red);border-radius:10px;
  padding:7px 14px;font-family:'Orbitron',sans-serif;font-size:.6rem;
  letter-spacing:2px;color:var(--red);z-index:999;
}
#offlineBadge.show{display:block}

@media(max-width:420px){
  .attendance-label{font-size:1.65rem;letter-spacing:4px}
  .faceid-label{font-size:1.2rem;letter-spacing:3px}
  .students-grid{grid-template-columns:1fr 1fr}
  .modal{padding:20px 14px}
  .brand{font-size:1.5rem;letter-spacing:3px}
  .profile-stats{gap:6px}
}
</style>
</head>
<body>

<!--══════════════════════════════════════
    PAGE 1 — ATTENDANCE
══════════════════════════════════════-->
<div class="page active" id="pageAttendance">
  <div class="topbar">
    <div class="brand" onclick="goHome()">STUDYGO</div>
    <div class="counter">
      <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      <span class="counter-text"><span id="count">0</span>/30</span>
    </div>
  </div>

  <!-- Attendance green card -->
  <div class="attendance-card" id="attendanceCard" onclick="activateAttendance(event)">
    <div class="card-deco"><span></span><span></span><span></span></div>
    <div class="attendance-label">ATTENDANCE</div>
    <div class="hint-text">↓ CLICK TO ADD STUDENT ↓</div>
    <div class="attendance-list" id="list"></div>
    <div class="add-area" id="addArea">
      <input id="nameInput" type="text" placeholder="Enter student name…" maxlength="40" autocomplete="off">
      <button onclick="addStudent(event)">ADD</button>
    </div>
  </div>

  <!-- Face ID card — full width -->
  <div class="faceid-hero" onclick="openCameraModal()">
    <div class="faceid-scanbar"></div>
    <div class="faceid-icon-wrap">👁️</div>
    <div class="faceid-label">FACE ID</div>
    <div class="faceid-sub">TAP TO SCAN · BIOMETRIC AUTH</div>
  </div>
</div>

<!--══════════════════════════════════════
    PAGE 2 — SCHOOL ADMIN
══════════════════════════════════════-->
<div class="page" id="pageSchool">
  <div class="topbar">
    <div class="brand" onclick="goHome()">STUDYGO</div>
    <div class="page-badge badge-yellow">SCHOOL ADMIN</div>
  </div>

  <div class="page-header fade-up">
    <div class="page-title" style="color:var(--yellow)">STUDENT FILE</div>
    <div class="page-subtitle">MANAGE DESCRIPTORS & RECORDS</div>
  </div>

  <div class="search-bar fade-up">
    <input type="text" id="schoolSearch" placeholder="Search students…" oninput="renderSchoolList()" autocomplete="off">
    <button class="btn-add-student" onclick="openAddStudentModal()">+ NEW STUDENT</button>
  </div>

  <div class="students-grid" id="schoolGrid"></div>
  <div class="empty-state" id="schoolEmpty" style="display:none">
    <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M20 8v4m2-2h-4"/></svg>
    <p>NO STUDENTS YET</p>
    <p style="font-family:'Rajdhani',sans-serif;font-size:.8rem;color:#1a2a50;letter-spacing:1px">Click + NEW STUDENT to register</p>
  </div>
</div>

<!--══════════════════════════════════════
    PAGE 3 — STUDENT PROFILE
══════════════════════════════════════-->
<div class="page" id="pageStudent">
  <div class="topbar">
    <div class="brand" onclick="goHome()">STUDYGO</div>
    <div class="page-badge badge-red">MY PROFILE</div>
  </div>

  <!-- Picker state -->
  <div id="studentPickerWrap" style="width:100%;max-width:700px;display:flex;flex-direction:column;gap:16px;align-items:center">
    <div class="page-header fade-up" style="align-items:center;text-align:center">
      <div class="page-title" style="color:var(--red)">WHO ARE YOU?</div>
      <div class="page-subtitle">SELECT YOUR PROFILE TO VIEW ATTENDANCE</div>
    </div>
    <div class="search-bar fade-up" style="max-width:500px">
      <input type="text" id="studentPickerSearch" placeholder="Search your name…" oninput="renderStudentPicker()" autocomplete="off">
    </div>
    <div class="student-picker-grid" id="studentPickerGrid"></div>
    <div id="studentPickerEmpty" style="display:none;flex-direction:column;align-items:center;gap:14px;padding:50px 20px;color:#1a2a50">
      <svg width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="#1a2a50" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
      <span style="font-family:'Orbitron',sans-serif;font-size:.65rem;letter-spacing:2px">NO STUDENTS REGISTERED</span>
      <span style="font-size:.78rem;color:#1a2a50;letter-spacing:.5px">Ask your school admin to add you first</span>
    </div>
  </div>

  <!-- Profile state -->
  <div id="studentProfileWrap" style="display:none;width:100%;max-width:700px;flex-direction:column;gap:20px;align-items:center">
    <div class="profile-hero fade-up">
      <div class="profile-big-avatar" id="profAvatar">🎓</div>
      <div class="profile-name" id="profName">—</div>
      <div class="profile-id" id="profId">—</div>
      <div class="profile-stats">
        <div class="stat-box">
          <div class="stat-val present-val" id="profPresent">0</div>
          <div class="stat-label">PRESENT</div>
        </div>
        <div class="stat-box">
          <div class="stat-val absent-val" id="profAbsent">0</div>
          <div class="stat-label">ABSENT</div>
        </div>
        <div class="stat-box">
          <div class="stat-val rate-val" id="profPct">0%</div>
          <div class="stat-label">RATE</div>
        </div>
      </div>
      <button class="sign-out-btn" onclick="studentLogout()">← BACK TO LIST</button>
    </div>

    <div class="calendar-wrap fade-up">
      <div class="cal-header">
        <div class="cal-title" id="calMonthTitle">—</div>
        <div class="cal-nav">
          <button onclick="calPrev()">‹</button>
          <button onclick="calNext()">›</button>
        </div>
      </div>
      <div class="cal-grid" id="calGrid"></div>
    </div>

    <div class="att-summary fade-up">
      <div class="att-summary-header">RECENT ATTENDANCE LOG</div>
      <div id="attLog"></div>
    </div>
  </div>
</div>

<!--══════════════════════════════════════
    BOTTOM NAV DOCK
══════════════════════════════════════-->
<nav class="nav-dock">
  <div class="nav-item active" id="nav0" onclick="showPage(0)">
    <svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
    ATTENDANCE
  </div>
  <div class="nav-item" id="nav1" onclick="showPage(1)">
    <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    SCHOOL
  </div>
  <div class="nav-item" id="nav2" onclick="showPage(2)">
    <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    STUDENT
  </div>
</nav>

<!--══════════════════════════════════════
    CAMERA MODAL (Face ID only)
══════════════════════════════════════-->
<div class="modal-overlay" id="camOverlay" onclick="if(event.target===this)closeCameraModal()">
  <div class="modal cam-modal">
    <div class="modal-title">👁️ FACE ID SCAN</div>
    <div class="camera-wrap">
      <div class="cam-placeholder" id="camPlaceholder">
        <svg viewBox="0 0 64 64"><rect x="8" y="18" width="48" height="34" rx="5"/><circle cx="32" cy="34" r="10"/><circle cx="32" cy="34" r="4"/><path d="M24 18 l2-6 h12 l2 6"/><circle cx="50" cy="26" r="2" fill="#1a2a50" stroke="none"/></svg>
        <span>CAMERA OFF</span>
      </div>
      <video id="camVideo" autoplay playsinline muted></video>
      <div class="scan-line" id="scanLine"></div>
      <div class="corners">
        <div class="corner tl" id="c1"></div><div class="corner tr" id="c2"></div>
        <div class="corner bl" id="c3"></div><div class="corner br" id="c4"></div>
      </div>
      <div class="processing-overlay" id="procOverlay">
        <div class="spinner"></div>
        <div class="proc-text">PROCESSING…</div>
      </div>
    </div>
    <div class="modal-status" id="camStatus">READY TO SCAN</div>
    <div class="modal-btns">
      <button class="btn-sm btn-generate" id="camStartBtn" onclick="startCameraModal()">START CAMERA</button>
      <button class="btn-sm btn-outline" onclick="closeCameraModal()">CLOSE</button>
    </div>
  </div>
</div>

<!--══════════════════════════════════════
    ADD STUDENT MODAL
══════════════════════════════════════-->
<div class="modal-overlay" id="addStudentOverlay" onclick="if(event.target===this)closeAddStudentModal()">
  <div class="modal detail-modal">
    <div class="modal-title">+ NEW STUDENT</div>
    <div class="modal-form">
      <div class="form-field">
        <label class="form-label">FULL NAME *</label>
        <input class="form-input" id="newStudentName" type="text" placeholder="e.g. Maria Garcia" maxlength="50" autocomplete="off">
      </div>
      <div class="form-field">
        <label class="form-label">STUDENT ID *</label>
        <input class="form-input" id="newStudentId" type="text" placeholder="e.g. STU-001" maxlength="20" autocomplete="off">
      </div>
      <div class="form-field">
        <label class="form-label">CLASS / GROUP</label>
        <input class="form-input" id="newStudentClass" type="text" placeholder="e.g. 3A" maxlength="20" autocomplete="off">
      </div>
    </div>
    <div class="modal-btns">
      <button class="btn-primary" onclick="saveNewStudent()">CREATE STUDENT</button>
      <button class="btn-close-modal" onclick="closeAddStudentModal()">CANCEL</button>
    </div>
  </div>
</div>

<!--══════════════════════════════════════
    STUDENT DETAIL MODAL
══════════════════════════════════════-->
<div class="modal-overlay" id="studentDetailOverlay" onclick="if(event.target===this)closeStudentDetail()">
  <div class="modal detail-modal" id="studentDetailModal">
    <input type="file" id="photoFileInput" accept="image/*" onchange="handlePhotoUpload(event)" style="display:none">

    <div class="detail-avatar" id="detailAvatar" onclick="document.getElementById('photoFileInput').click()">
      <span id="detailAvatarEmoji">👤</span>
      <img id="detailAvatarImg" src="" style="display:none">
      <div class="upload-hint">📷 UPLOAD PHOTO</div>
    </div>

    <div class="detail-name" id="detailName">—</div>
    <div class="detail-meta" id="detailMeta"></div>

    <div class="divider"></div>

    <div class="descriptor-section" style="width:100%">
      <div class="desc-title">FACIAL DESCRIPTOR</div>
      <div class="descriptor-status" id="descStatus">
        <div class="desc-dot none" id="descDot"></div>
        <span id="descText">No descriptor generated</span>
      </div>
      <div class="desc-actions">
        <button class="btn-sm btn-generate" id="btnGenerate" onclick="generateDescriptor()">⚡ GENERATE FROM PHOTO</button>
        <button class="btn-sm btn-danger" id="btnClearDesc" onclick="clearDescriptor()" style="display:none">🗑 CLEAR</button>
      </div>
      <div id="descProgress" style="display:none;margin-top:10px;font-size:.68rem;letter-spacing:1.5px;color:var(--baby)"></div>
    </div>

    <div class="divider"></div>

    <div class="descriptor-section" style="width:100%">
      <div class="desc-title">ATTENDANCE RECORD</div>
      <div id="detailAttLog" class="att-log"></div>
      <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">
        <button class="btn-sm btn-generate" onclick="markPresentToday()">✓ PRESENT TODAY</button>
        <button class="btn-sm btn-danger" onclick="markAbsentToday()">✗ ABSENT TODAY</button>
      </div>
    </div>

    <div class="divider"></div>
    <div class="modal-btns">
      <button class="btn-sm btn-danger" style="flex:1" onclick="deleteCurrentStudent()">DELETE STUDENT</button>
      <button class="btn-close-modal" onclick="closeStudentDetail()">CLOSE</button>
    </div>
  </div>
</div>

<div id="toast"></div>
<div id="offlineBadge">⚡ OFFLINE</div>

<script>
/*════════════════════════════════════
  DB
════════════════════════════════════*/
const DB_KEY='studygo_db';
let db=loadDB();
function loadDB(){
  try{ const r=localStorage.getItem(DB_KEY); if(r) return JSON.parse(r); }catch(e){}
  return{students:[],attendance:[],session:{present:[],date:today()}};
}
function saveDB(){ try{ localStorage.setItem(DB_KEY,JSON.stringify(db)); }catch(e){} }
function today(){ return new Date().toISOString().slice(0,10); }
function fmt(d){ return new Date(d+'T00:00:00').toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'}); }
if(!db.session||db.session.date!==today()){ db.session={present:[],date:today()}; saveDB(); }

/*════════════════════════════════════
  NAVIGATION
════════════════════════════════════*/
const PAGES=['pageAttendance','pageSchool','pageStudent'];
const NAV_CLS=['','ynav','rnav'];
let curPage=0;

function showPage(n){
  PAGES.forEach((p,i)=>{
    document.getElementById(p).classList.toggle('active',i===n);
    const ni=document.getElementById('nav'+i);
    ni.className='nav-item'+(i===n?' active':'')+(NAV_CLS[i]?' '+NAV_CLS[i]:'');
  });
  curPage=n;
  if(n===1) renderSchoolList();
  if(n===2) renderStudentPicker();
}
function goHome(){ showPage(0); }

/*════════════════════════════════════
  PAGE 1 — ATTENDANCE
════════════════════════════════════*/
const MAX=30;
const listEl=document.getElementById('list');
const countEl=document.getElementById('count');
const nameInput=document.getElementById('nameInput');
const aCard=document.getElementById('attendanceCard');

nameInput.addEventListener('keydown',e=>{ if(e.key==='Enter') addStudent(e); });
document.addEventListener('click',e=>{
  if(!aCard.contains(e.target)&&!e.target.closest('.modal')) aCard.classList.remove('active');
});

function activateAttendance(e){
  aCard.classList.add('active');
  setTimeout(()=>nameInput.focus(),60);
}
function addStudent(e){
  if(e) e.stopPropagation();
  const name=nameInput.value.trim();
  if(!name) return;
  if(db.session.present.length>=MAX){ showToast('MAX 30 REACHED','red'); return; }
  if(db.session.present.includes(name)){ showToast('ALREADY MARKED','yellow'); return; }
  db.session.present.push(name);
  const m=db.students.find(s=>s.name.toLowerCase()===name.toLowerCase());
  if(m) markAttendance(m.id,today(),true);
  nameInput.value=''; nameInput.focus();
  saveDB(); renderAttList();
}
function renderAttList(){
  listEl.innerHTML='';
  db.session.present.forEach((name,i)=>{
    const r=document.createElement('div'); r.className='student-entry';
    r.innerHTML=`<span class="student-num">${String(i+1).padStart(2,'0')}</span>
      <span class="student-name">${esc(name)}</span>
      <span class="student-check">★</span>`;
    listEl.appendChild(r);
  });
  listEl.scrollTop=listEl.scrollHeight;
  countEl.textContent=db.session.present.length;
  countEl.style.color=db.session.present.length>=MAX?'var(--red)':'var(--yellow)';
}
renderAttList();

/*════════════════════════════════════
  PAGE 2 — SCHOOL ADMIN
════════════════════════════════════*/
function renderSchoolList(){
  const q=(document.getElementById('schoolSearch').value||'').toLowerCase();
  const grid=document.getElementById('schoolGrid');
  const empty=document.getElementById('schoolEmpty');
  const f=db.students.filter(s=>!q||s.name.toLowerCase().includes(q)||s.id.toLowerCase().includes(q));
  grid.innerHTML='';
  if(f.length===0){ empty.style.display='flex'; return; }
  empty.style.display='none';
  f.forEach(s=>{
    const att=getAtt(s.id);
    const pct=att.total>0?Math.round(att.present/att.total*100):0;
    const el=document.createElement('div'); el.className='student-card';
    el.onclick=()=>openStudentDetail(s.id);
    const av=s.photo?`<img src="${s.photo}" alt="">`:`<span>${s.name.charAt(0).toUpperCase()}</span>`;
    el.innerHTML=`
      <div class="student-avatar">${av}
        <div class="avatar-badge ${s.descriptor?'has-descriptor':'no-descriptor'}">${s.descriptor?'✓':'?'}</div>
      </div>
      <div class="sc-name">${esc(s.name)}</div>
      <div class="sc-id">${esc(s.id)}${s.class?' · '+esc(s.class):''}</div>
      <div class="sc-attendance">${pct}% · ${att.present}/${att.total} days</div>`;
    grid.appendChild(el);
  });
}

function getAtt(sid){
  const r=db.attendance.filter(a=>a.sid===sid);
  return{total:r.length,present:r.filter(a=>a.present).length};
}
function markAttendance(sid,date,present){
  const i=db.attendance.findIndex(a=>a.sid===sid&&a.date===date);
  if(i>-1) db.attendance[i].present=present;
  else db.attendance.push({sid,date,present});
  saveDB();
}

/* ADD STUDENT */
function openAddStudentModal(){
  ['newStudentName','newStudentId','newStudentClass'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('addStudentOverlay').classList.add('open');
  setTimeout(()=>document.getElementById('newStudentName').focus(),100);
}
function closeAddStudentModal(){ document.getElementById('addStudentOverlay').classList.remove('open'); }
function saveNewStudent(){
  const name=document.getElementById('newStudentName').value.trim();
  const id=document.getElementById('newStudentId').value.trim();
  const cls=document.getElementById('newStudentClass').value.trim();
  if(!name||!id){ showToast('NAME & ID REQUIRED','red'); return; }
  if(db.students.find(s=>s.id===id)){ showToast('ID ALREADY EXISTS','red'); return; }
  db.students.push({name,id,class:cls,photo:null,descriptor:null,createdAt:today()});
  saveDB(); closeAddStudentModal(); renderSchoolList(); showToast('STUDENT ADDED','green');
}

/* STUDENT DETAIL */
let curSid=null;
function openStudentDetail(sid){
  curSid=sid; const s=db.students.find(s=>s.id===sid); if(!s) return;
  const img=document.getElementById('detailAvatarImg');
  const em=document.getElementById('detailAvatarEmoji');
  if(s.photo){ img.src=s.photo; img.style.display='block'; em.style.display='none'; }
  else{ img.style.display='none'; em.style.display='block'; em.textContent=s.name.charAt(0).toUpperCase(); }
  document.getElementById('detailName').textContent=s.name;
  document.getElementById('detailMeta').innerHTML=`
    <span class="meta-tag meta-blue">${esc(s.id)}</span>
    ${s.class?`<span class="meta-tag meta-yellow">CLASS ${esc(s.class)}</span>`:''}
    <span class="meta-tag meta-white">ADDED ${s.createdAt||'—'}</span>`;
  updateDescUI(s); renderDetailLog(sid);
  document.getElementById('studentDetailOverlay').classList.add('open');
}
function closeStudentDetail(){ document.getElementById('studentDetailOverlay').classList.remove('open'); curSid=null; }

function updateDescUI(s){
  const dot=document.getElementById('descDot');
  const txt=document.getElementById('descText');
  const btnC=document.getElementById('btnClearDesc');
  const btnG=document.getElementById('btnGenerate');
  if(s.descriptor){
    dot.className='desc-dot ok'; txt.textContent='Descriptor ready ('+s.descriptor.length+' features)';
    btnC.style.display='inline-flex'; btnG.textContent='⚡ REGENERATE';
  } else {
    dot.className='desc-dot none'; txt.textContent='No descriptor — upload a photo first';
    btnC.style.display='none'; btnG.textContent='⚡ GENERATE FROM PHOTO';
  }
}
function renderDetailLog(sid){
  const log=document.getElementById('detailAttLog');
  const recs=db.attendance.filter(a=>a.sid===sid).sort((a,b)=>b.date.localeCompare(a.date)).slice(0,20);
  if(!recs.length){ log.innerHTML='<div style="font-size:.78rem;color:#1a2a50;padding:6px 0;letter-spacing:1px">No records yet</div>'; return; }
  log.innerHTML=recs.map(r=>`<div class="att-row"><div class="att-date">${fmt(r.date)}</div><div class="${r.present?'att-present':'att-absent'}">${r.present?'PRESENT':'ABSENT'}</div></div>`).join('');
}
function markPresentToday(){
  if(!curSid) return; markAttendance(curSid,today(),true);
  const s=db.students.find(s=>s.id===curSid);
  if(s&&!db.session.present.includes(s.name)){ db.session.present.push(s.name); renderAttList(); }
  saveDB(); renderDetailLog(curSid); renderSchoolList(); showToast('MARKED PRESENT','green');
}
function markAbsentToday(){
  if(!curSid) return; markAttendance(curSid,today(),false);
  const s=db.students.find(s=>s.id===curSid);
  if(s){ db.session.present=db.session.present.filter(n=>n!==s.name); renderAttList(); }
  saveDB(); renderDetailLog(curSid); renderSchoolList(); showToast('MARKED ABSENT','red');
}
function deleteCurrentStudent(){
  if(!curSid) return;
  if(!confirm('Delete this student permanently?')) return;
  db.students=db.students.filter(s=>s.id!==curSid);
  db.attendance=db.attendance.filter(a=>a.sid!==curSid);
  saveDB(); closeStudentDetail(); renderSchoolList(); showToast('STUDENT DELETED','red');
}

/* PHOTO */
function handlePhotoUpload(e){
  const file=e.target.files[0]; if(!file||!curSid) return;
  const reader=new FileReader();
  reader.onload=ev=>{
    const s=db.students.find(s=>s.id===curSid); if(!s) return;
    s.photo=ev.target.result; saveDB();
    const img=document.getElementById('detailAvatarImg');
    const em=document.getElementById('detailAvatarEmoji');
    img.src=s.photo; img.style.display='block'; em.style.display='none';
    showToast('PHOTO UPLOADED','green'); renderSchoolList();
  };
  reader.readAsDataURL(file); e.target.value='';
}

/* DESCRIPTOR */
let faLoaded=false,faLoading=false;
async function ensureFA(){
  if(faLoaded) return true;
  if(typeof faceapi==='undefined'){
    return new Promise(res=>{
      const t=setInterval(()=>{ if(typeof faceapi!=='undefined'){clearInterval(t);loadModels().then(res);} },200);
      setTimeout(()=>{ clearInterval(t); res(false); },12000);
    });
  }
  return loadModels();
}
async function loadModels(){
  if(faLoading) return false;
  faLoading=true;
  try{
    const URL='https://cdn.jsdelivr.net/npm/@vladmandic/face-api/model';
    await Promise.all([
      faceapi.nets.ssdMobilenetv1.loadFromUri(URL),
      faceapi.nets.faceLandmark68Net.loadFromUri(URL),
      faceapi.nets.faceRecognitionNet.loadFromUri(URL),
    ]);
    faLoaded=true; return true;
  }catch(e){ faLoading=false; return false; }
}
async function generateDescriptor(){
  if(!curSid) return;
  const s=db.students.find(s=>s.id===curSid);
  if(!s||!s.photo){ showToast('UPLOAD A PHOTO FIRST','red'); return; }
  const btn=document.getElementById('btnGenerate');
  const prog=document.getElementById('descProgress');
  btn.disabled=true; prog.style.display='block'; prog.textContent='Loading models…';
  try{
    if(!await ensureFA()) throw new Error('face-api unavailable');
    prog.textContent='Detecting face…';
    const img=new Image(); img.src=s.photo;
    await new Promise((r,j)=>{ img.onload=r; img.onerror=j; });
    const det=await faceapi.detectSingleFace(img).withFaceLandmarks().withFaceDescriptor();
    if(!det) throw new Error('No face detected in photo');
    s.descriptor=Array.from(det.descriptor); saveDB();
    prog.style.display='none'; updateDescUI(s); renderSchoolList(); showToast('DESCRIPTOR READY ✓','green');
  }catch(err){
    prog.textContent='ERROR: '+(err.message||'Unknown').toUpperCase().slice(0,50);
    showToast('FAILED: '+err.message.slice(0,28).toUpperCase(),'red');
  } finally{ btn.disabled=false; }
}
function clearDescriptor(){
  if(!curSid) return;
  const s=db.students.find(s=>s.id===curSid);
  if(s){ s.descriptor=null; saveDB(); updateDescUI(s); renderSchoolList(); showToast('CLEARED','red'); }
}

/*════════════════════════════════════
  PAGE 3 — STUDENT PROFILE (no ID)
════════════════════════════════════*/
let profSid=null,calY=new Date().getFullYear(),calM=new Date().getMonth();

function renderStudentPicker(){
  const q=(document.getElementById('studentPickerSearch').value||'').toLowerCase();
  const grid=document.getElementById('studentPickerGrid');
  const empty=document.getElementById('studentPickerEmpty');
  const f=db.students.filter(s=>!q||s.name.toLowerCase().includes(q));
  grid.innerHTML='';
  if(f.length===0){ empty.style.display='flex'; return; }
  empty.style.display='none';
  f.forEach(s=>{
    const el=document.createElement('div'); el.className='picker-card';
    el.onclick=()=>selectStudent(s.id);
    const av=s.photo?`<img src="${s.photo}" alt="">`:`<span>${s.name.charAt(0).toUpperCase()}</span>`;
    el.innerHTML=`
      <div class="picker-avatar">${av}</div>
      <div class="picker-name">${esc(s.name)}</div>
      ${s.class?`<div class="picker-class">CLASS ${esc(s.class)}</div>`:''}`;
    grid.appendChild(el);
  });
}

function selectStudent(sid){
  profSid=sid;
  document.getElementById('studentPickerWrap').style.display='none';
  const w=document.getElementById('studentProfileWrap');
  w.style.display='flex'; renderProfileData();
}

function studentLogout(){
  profSid=null;
  document.getElementById('studentProfileWrap').style.display='none';
  document.getElementById('studentPickerWrap').style.display='flex';
  renderStudentPicker();
}

function renderProfileData(){
  if(!profSid) return;
  const s=db.students.find(s=>s.id===profSid); if(!s){ studentLogout(); return; }
  const av=document.getElementById('profAvatar');
  av.innerHTML='';
  if(s.photo){
    const img=document.createElement('img');
    img.src=s.photo; img.style.cssText='width:100%;height:100%;object-fit:cover;border-radius:50%';
    av.appendChild(img);
  } else { av.textContent=s.name.charAt(0).toUpperCase(); }
  document.getElementById('profName').textContent=s.name;
  document.getElementById('profId').textContent=s.id+(s.class?' · CLASS '+s.class:'');
  const att=getAtt(s.id);
  const pct=att.total>0?Math.round(att.present/att.total*100):0;
  document.getElementById('profPresent').textContent=att.present;
  document.getElementById('profAbsent').textContent=att.total-att.present;
  document.getElementById('profPct').textContent=pct+'%';
  renderCalendar(); renderAttLog();
}

function renderStudentProfile(){ if(profSid) renderProfileData(); else renderStudentPicker(); }

function renderCalendar(){
  if(!profSid) return;
  const MO=['JANUARY','FEBRUARY','MARCH','APRIL','MAY','JUNE','JULY','AUGUST','SEPTEMBER','OCTOBER','NOVEMBER','DECEMBER'];
  document.getElementById('calMonthTitle').textContent=MO[calM]+' '+calY;
  const grid=document.getElementById('calGrid'); grid.innerHTML='';
  ['SUN','MON','TUE','WED','THU','FRI','SAT'].forEach(d=>{ const e=document.createElement('div'); e.className='cal-day-name'; e.textContent=d; grid.appendChild(e); });
  const first=new Date(calY,calM,1).getDay();
  const days=new Date(calY,calM+1,0).getDate();
  const todayStr=today();
  const recs=db.attendance.filter(a=>a.sid===profSid);
  for(let i=0;i<first;i++){ const e=document.createElement('div'); e.className='cal-day empty'; grid.appendChild(e); }
  for(let d=1;d<=days;d++){
    const ds=`${calY}-${String(calM+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const rec=recs.find(r=>r.date===ds);
    const e=document.createElement('div'); e.textContent=d;
    let cls='cal-day';
    if(ds===todayStr) cls+=' today';
    else if(ds>todayStr) cls+=' future';
    else if(rec?.present) cls+=' present';
    else if(rec) cls+=' absent';
    e.className=cls; grid.appendChild(e);
  }
}
function calPrev(){ calM--; if(calM<0){calM=11;calY--;} renderCalendar(); }
function calNext(){ calM++; if(calM>11){calM=0;calY++;} renderCalendar(); }

function renderAttLog(){
  if(!profSid) return;
  const log=document.getElementById('attLog');
  const recs=db.attendance.filter(a=>a.sid===profSid).sort((a,b)=>b.date.localeCompare(a.date)).slice(0,30);
  if(!recs.length){ log.innerHTML='<div class="att-item"><span style="color:#1a2a50;font-size:.82rem;letter-spacing:1px">No records yet</span></div>'; return; }
  const s=db.students.find(s=>s.id===profSid);
  log.innerHTML=recs.map(r=>`
    <div class="att-item">
      <div class="att-dot ${r.present?'p':'a'}"></div>
      <div><div class="att-item-date">${fmt(r.date)}</div>${s?.class?`<div class="att-item-class">CLASS ${esc(s.class)}</div>`:''}</div>
      <div class="att-item-status ${r.present?'p':'a'}">${r.present?'PRESENT':'ABSENT'}</div>
    </div>`).join('');
}

/*════════════════════════════════════
  CAMERA MODAL
════════════════════════════════════*/
let camStream=null;
const camOverlay=document.getElementById('camOverlay');
const camVideo=document.getElementById('camVideo');
const scanLine=document.getElementById('scanLine');
const camHolder=document.getElementById('camPlaceholder');
const camStatus=document.getElementById('camStatus');
const camStartBtn=document.getElementById('camStartBtn');
const cornerEls=['c1','c2','c3','c4'].map(id=>document.getElementById(id));
const procOverlay=document.getElementById('procOverlay');

function openCameraModal(){
  camStatus.textContent='READY TO SCAN';
  camStartBtn.textContent='START CAMERA'; camStartBtn.disabled=false;
  stopCam(); camVideo.classList.remove('live'); camHolder.style.display='flex';
  scanLine.classList.remove('active'); cornerEls.forEach(c=>c.classList.remove('on'));
  procOverlay.classList.remove('show'); camOverlay.classList.add('open');
}
function closeCameraModal(){
  stopCam(); camOverlay.classList.remove('open');
  camVideo.classList.remove('live'); scanLine.classList.remove('active');
  cornerEls.forEach(c=>c.classList.remove('on')); camHolder.style.display='flex';
}
function startCameraModal(){
  if(!navigator.mediaDevices?.getUserMedia){ camStatus.textContent='CAMERA NOT SUPPORTED'; return; }
  camStatus.textContent='REQUESTING PERMISSION…'; camStartBtn.disabled=true;
  navigator.mediaDevices.getUserMedia({video:{facingMode:'user'},audio:false})
    .catch(()=>navigator.mediaDevices.getUserMedia({video:true,audio:false}))
    .then(s=>{
      camStream=s; camVideo.srcObject=s; camVideo.classList.add('live');
      camHolder.style.display='none'; scanLine.classList.add('active');
      cornerEls.forEach(c=>c.classList.add('on'));
      camStatus.textContent='SCANNING — LOOK AT THE CAMERA'; camStartBtn.textContent='SCANNING…';
    })
    .catch(err=>{
      camStartBtn.disabled=false; camStartBtn.textContent='RETRY';
      camStatus.textContent=err.name==='NotAllowedError'?'PERMISSION DENIED':err.name==='NotFoundError'?'NO CAMERA FOUND':'ERROR: '+(err.message||err.name).slice(0,40).toUpperCase();
    });
}
function stopCam(){ if(camStream){ camStream.getTracks().forEach(t=>t.stop()); camStream=null; camVideo.srcObject=null; } }

/*════════════════════════════════════
  UTILS
════════════════════════════════════*/
function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

let toastT=null;
function showToast(msg,type='green'){
  const t=document.getElementById('toast');
  t.textContent=msg; t.className='show '+(type||'');
  if(toastT) clearTimeout(toastT);
  toastT=setTimeout(()=>t.className='',2400);
}

window.addEventListener('online',()=>document.getElementById('offlineBadge').classList.remove('show'));
window.addEventListener('offline',()=>document.getElementById('offlineBadge').classList.add('show'));
if(!navigator.onLine) document.getElementById('offlineBadge').classList.add('show');

document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){ closeCameraModal(); closeStudentDetail(); closeAddStudentModal(); }
});

if('serviceWorker' in navigator){
  window.addEventListener('load',()=>navigator.serviceWorker.register('./sw.js').catch(()=>{}));
}
</script>
</body>
